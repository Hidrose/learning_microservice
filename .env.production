# Environment variables for EC2 Production
# Copy this file to .env on EC2 and update IP address

# Public URLs (thay YOUR_EC2_IP bằng IP EC2 của bạn)
FRONTEND_URL=http://YOUR_EC2_IP
BACKEND_URL=http://YOUR_EC2_IP:8090
VITE_BACKEND_URL=http://YOUR_EC2_IP:8090

# Internal Docker URLs (không cần thay đổi)
EUREKA_URL=http://eureka-server:8761/eureka/
N8N_URL=http://n8n:5678
