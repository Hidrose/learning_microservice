# ============================================================
# Copy file này thành .env và điền giá trị thật
# KHÔNG commit file .env lên Git
# ============================================================

# Docker Hub
DOCKERHUB_USERNAME=your_dockerhub_username

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=86400000

# MySQL / Database chung
DATASOURCE_USERNAME=avnadmin
DATASOURCE_PASSWORD=your_db_password

# DB URL từng service (thay "userdb" bằng tên db tương ứng)
DATASOURCE_URL_USER=jdbc:mysql://your-db-host:port/userdb?ssl-mode=REQUIRED
DATASOURCE_URL_AUTH=jdbc:mysql://your-db-host:port/authdb?ssl-mode=REQUIRED
DATASOURCE_URL_PRODUCT=jdbc:mysql://your-db-host:port/productdb?ssl-mode=REQUIRED
DATASOURCE_URL_CATEGORY=jdbc:mysql://your-db-host:port/categorydb?ssl-mode=REQUIRED
DATASOURCE_URL_BRAND=jdbc:mysql://your-db-host:port/branddb?ssl-mode=REQUIRED
DATASOURCE_URL_ORDER=jdbc:mysql://your-db-host:port/orderdb?ssl-mode=REQUIRED
DATASOURCE_URL_PAYMENT=jdbc:mysql://your-db-host:port/paymentdb?ssl-mode=REQUIRED

# MongoDB
MONGODB_URI_CART=mongodb+srv://user:pass@cluster/cartdb
MONGODB_URI_CHAT=mongodb+srv://user:pass@cluster/chatdb

# Redis
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (SMTP)
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_app_password

# URLs
FRONTEND_URL=http://your-ec2-public-ip
BACKEND_URL=http://your-ec2-public-ip:8090

# Momo Payment
MOMO_PARTNERCODE=MOMO
MOMO_ACCESSKEY=your_access_key
MOMO_SECRETKEY=your_secret_key
MOMO_URL=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REFUND_URL=https://test-payment.momo.vn/v2/gateway/api/refund
